def base_schedule_from_hour(hour: int) -> float:
    if 0 <= hour < 6:
        return 74.0
    if 6 <= hour < 9:
        return 72.0
    if 9 <= hour < 17:
        return 76.0
    if 17 <= hour < 22:
        return 72.0
    return 74.0

if "T_schedule_base_F" not in df.columns:
    df["T_schedule_base_F"] = df["hour"].apply(base_schedule_from_hour)
