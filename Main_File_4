# =========================================================
# HELPERS
# =========================================================
def clamp(x, lo, hi):
    return float(np.minimum(np.maximum(x, lo), hi))

def occupied_gain(hour: int) -> float:
    return INTERNAL_GAIN_DAY if 7 <= hour < 22 else INTERNAL_GAIN_NIGHT

def compute_setpoint(T_schedule, P_clear, P_avg, sigma_actual, alpha):
    sigma = max(float(sigma_actual), SIGMA_FLOOR)

    # alpha ต่ำ -> price response อ่อน -> comfort มากกว่า
    # alpha สูง -> price response แรง -> ประหยัดมากกว่า
    alpha_gain = 0.6 + 1.4 * alpha   # 0.4 -> 1.16, 0.7 -> 1.58

    delta = alpha_gain * ((P_clear - P_avg) * T_RANGE_ALLOWED) / (K_BID * sigma)
    T_set = T_schedule + delta
    return clamp(T_set, T_MIN, T_MAX)

def hvac_power_fraction(T_room, T_set, prev_power_frac):
    error = T_room - T_set
    raw = error / HVAC_CONTROL_BAND
    raw = clamp(raw, 0.0, 1.0)

    # smoother response
    power_frac = 0.6 * prev_power_frac + 0.4 * raw
    return clamp(power_frac, 0.0, 1.0)

def thermal_step_cooling(T_room, T_out, power_frac, hour, dt_hours=1.0):
    env_term = ENVELOPE_GAIN * (T_out - T_room)
    int_term = occupied_gain(hour)
    cool_term = HVAC_COOLING_GAIN * power_frac
    noise = np.random.normal(0.0, PROCESS_NOISE_STD)

    dT = dt_hours * (env_term + int_term - cool_term) / THERMAL_MASS
    T_next = T_room + dT + noise
    return clamp(T_next, T_MIN, T_MAX)

def normalize_state_vector(
    T_set,
    T_room,
    T_schedule_base,
    T_schedule_applied,
    T_out,
    P_clear,
    P_avg,
    P_std,
    hour_sin,
    hour_cos,
    prev_action,
    prev_power_frac,
    alpha,
):
    return np.array([
        (T_set - 75.0) / 10.0,
        (T_room - 75.0) / 10.0,
        (T_schedule_base - 75.0) / 10.0,
        (T_schedule_applied - 75.0) / 10.0,
        (T_out - 75.0) / 15.0,
        (P_clear - train_df[PRICE_COL].mean()) / max(train_df[PRICE_COL].std(), 1e-6),
        (P_avg - train_df["P_average_24h"].mean()) / max(train_df["P_average_24h"].std(), 1e-6),
        (P_std - train_df["sigma_actual_24h"].mean()) / max(train_df["sigma_actual_24h"].std(), 1e-6),
        hour_sin,
        hour_cos,
        prev_action / ACTION_MAX_DELTA,
        prev_power_frac,
        alpha,
    ], dtype=np.float32)

def reward_fn(
    E_hvac_kwh,
    P_clear,
    T_room,
    T_schedule_base,
    T_schedule_current,
    alpha,
    action,
    prev_action,
    power_frac,
    prev_power_frac,
):
    energy_cost = E_hvac_kwh * P_clear
    T_dev = T_room - T_schedule_base

    # normalize cost ให้ขนาดใกล้กับ comfort
    cost_norm = energy_cost / 8.0

    # alpha ต่ำ -> comfort penalty แรงขึ้น
    # alpha สูง -> comfort penalty เบาลง
    comfort_weight = (1.0 - alpha) * (2.8 - 1.5 * alpha)

    comfort_term = comfort_weight * (T_dev / 2.0) ** 2

    reward = -alpha * cost_norm - comfort_term

    # stabilization
    reward -= 0.015 * (action / ACTION_MAX_DELTA) ** 2
    reward -= 0.01 * ((action - prev_action) / ACTION_MAX_DELTA) ** 2
    reward -= 0.003 * (power_frac - prev_power_frac) ** 2
    reward -= 0.001 * (T_room - T_schedule_current) ** 2

    if abs(action) > 0.95 * ACTION_MAX_DELTA:
        reward -= 0.02

    return reward


# =========================================================
# ENVIRONMENT
# =========================================================
class HVACEnv:
    def __init__(self, data: pd.DataFrame, alpha: float, episode_len: int = EPISODE_LEN, dt_hours: float = DT_HOURS):
        self.data = data.reset_index(drop=True)
        self.alpha = float(alpha)
        self.episode_len = min(int(episode_len), len(self.data) - 2)
        self.dt_hours = float(dt_hours)
        self.max_start = len(self.data) - self.episode_len - 1
        if self.max_start < 1:
            raise ValueError("Dataset too short for chosen episode_len")
        self.reset()

    @property
    def state_dim(self):
        return 13

    @property
    def action_dim(self):
        return 1

    def _build_state(self):
        row = self.data.iloc[self.idx]
        hour = float(row["hour"])
        hour_sin = math.sin(2.0 * math.pi * hour / 24.0)
        hour_cos = math.cos(2.0 * math.pi * hour / 24.0)

        T_schedule_base = float(row["T_schedule_base_F"])
        P_clear = float(row[PRICE_COL])
        P_avg = float(row["P_average_24h"])
        P_std = float(row["sigma_actual_24h"])
        T_out = float(row["T_out_F"])

        T_set = compute_setpoint(
            T_schedule=self.current_schedule,
            P_clear=P_clear,
            P_avg=P_avg,
            sigma_actual=P_std,
            alpha=self.alpha,
        )

        return normalize_state_vector(
            T_set=T_set,
            T_room=self.T_room,
            T_schedule_base=T_schedule_base,
            T_schedule_applied=self.current_schedule,
            T_out=T_out,
            P_clear=P_clear,
            P_avg=P_avg,
            P_std=P_std,
            hour_sin=hour_sin,
            hour_cos=hour_cos,
            prev_action=self.prev_action,
            prev_power_frac=self.prev_power_frac,
            alpha=self.alpha,
        )

    def reset(self, start_idx=None):
        if start_idx is None:
            start_idx = np.random.randint(0, self.max_start)

        self.start_idx = int(start_idx)
        self.idx = int(start_idx)
        self.step_count = 0
        self.prev_action = 0.0
        self.prev_power_frac = 0.0

        row = self.data.iloc[self.idx]
        self.T_room = float(row["T_schedule_base_F"]) + np.random.uniform(-1.0, 1.0)
        self.current_schedule = float(row["T_schedule_base_F"])
        self.done = False
        self.history = []

        return self._build_state()

    def step(self, action):
        if self.done:
            raise RuntimeError("Episode finished. Call reset().")

        row = self.data.iloc[self.idx]
        hour = int(row["hour"])
        T_schedule_base = float(row["T_schedule_base_F"])
        T_out = float(row["T_out_F"])
        P_clear = float(row[PRICE_COL])
        P_avg = float(row["P_average_24h"])
        P_std = float(row["sigma_actual_24h"])

        action = float(np.clip(action, -ACTION_MAX_DELTA, ACTION_MAX_DELTA))
        prev_action_before_update = self.prev_action
        prev_power_before_update = self.prev_power_frac

        target_schedule = clamp(T_schedule_base + action, T_MIN, T_MAX)

        self.current_schedule = (
            0.55 * self.current_schedule
            + 0.45 * target_schedule
        )
        self.current_schedule = clamp(self.current_schedule, T_MIN, T_MAX)

        T_set = compute_setpoint(
            T_schedule=self.current_schedule,
            P_clear=P_clear,
            P_avg=P_avg,
            sigma_actual=P_std,
            alpha=self.alpha,
        )

        power_frac = hvac_power_fraction(
            T_room=self.T_room,
            T_set=T_set,
            prev_power_frac=prev_power_before_update,
        )

        E_hvac = HVAC_POWER_KW_MAX * power_frac * self.dt_hours
        hourly_cost = E_hvac * P_clear
        T_dev = self.T_room - T_schedule_base

        reward = reward_fn(
            E_hvac_kwh=E_hvac,
            P_clear=P_clear,
            T_room=self.T_room,
            T_schedule_base=T_schedule_base,
            T_schedule_current=self.current_schedule,
            alpha=self.alpha,
            action=action,
            prev_action=prev_action_before_update,
            power_frac=power_frac,
            prev_power_frac=prev_power_before_update,
        )

        self.history.append({
            DATETIME_COL: row[DATETIME_COL],
            "T_room": self.T_room,
            "T_schedule_base": T_schedule_base,
            "T_schedule": self.current_schedule,
            "T_set": T_set,
            "power_frac": power_frac,
            "hvac_on": 1 if power_frac > 1e-3 else 0,
            "E_hvac_kwh": E_hvac,
            "hourly_cost": hourly_cost,
            "T_dev": T_dev,
            "reward": reward,
            "action_delta_schedule": action,
            PRICE_COL: P_clear,
            "T_out_F": T_out,
        })

        self.T_room = thermal_step_cooling(
            T_room=self.T_room,
            T_out=T_out,
            power_frac=power_frac,
            hour=hour,
            dt_hours=self.dt_hours,
        )

        self.prev_action = action
        self.prev_power_frac = power_frac
        self.idx += 1
        self.step_count += 1
        self.done = (self.step_count >= self.episode_len) or (self.idx >= len(self.data) - 1)

        next_state = self._build_state() if not self.done else np.zeros(self.state_dim, dtype=np.float32)
        return next_state, reward, self.done, {}

    def rollout_dataframe(self):
        return pd.DataFrame(self.history)


# =========================================================
# BASELINE
# =========================================================
def simulate_baseline(data: pd.DataFrame, alpha: float, start_idx: int, episode_len: int):
    env = HVACEnv(data, alpha=alpha, episode_len=episode_len, dt_hours=DT_HOURS)
    _ = env.reset(start_idx=start_idx)
    done = False
    while not done:
        _, _, done, _ = env.step(0.0)
    return env.rollout_dataframe()


# =========================================================
# OU NOISE
# =========================================================
class OUNoise:
    def __init__(self, size, theta=0.15, sigma=0.2, dt=1.0):
        self.size = size
        self.theta = theta
        self.sigma = sigma
        self.dt = dt
        self.state = np.zeros(self.size, dtype=np.float32)

    def reset(self):
        self.state = np.zeros(self.size, dtype=np.float32)

    def sample(self):
        dx = self.theta * (-self.state) * self.dt + self.sigma * np.sqrt(self.dt) * np.random.randn(self.size)
        self.state = self.state + dx
        return self.state.copy()


# =========================================================
# REPLAY BUFFER
# =========================================================
class ReplayBuffer:
    def __init__(self, capacity: int):
        self.buffer = deque(maxlen=capacity)

    def add(self, s, a, r, ns, d):
        self.buffer.append((s, a, r, ns, d))

    def sample(self, batch_size: int):
        batch = random.sample(self.buffer, batch_size)
        s, a, r, ns, d = zip(*batch)
        return (
            torch.tensor(np.array(s), dtype=torch.float32, device=DEVICE),
            torch.tensor(np.array(a), dtype=torch.float32, device=DEVICE),
            torch.tensor(np.array(r), dtype=torch.float32, device=DEVICE).unsqueeze(1),
            torch.tensor(np.array(ns), dtype=torch.float32, device=DEVICE),
            torch.tensor(np.array(d), dtype=torch.float32, device=DEVICE).unsqueeze(1),
        )

    def __len__(self):
        return len(self.buffer)


# =========================================================
# NETWORKS
# =========================================================
class Actor(nn.Module):
    def __init__(self, state_dim, action_dim, action_limit):
        super().__init__()
        self.action_limit = action_limit
        self.net = nn.Sequential(
            nn.Linear(state_dim, 128),
            nn.ReLU(),
            nn.Linear(128, 128),
            nn.ReLU(),
            nn.Linear(128, action_dim),
            nn.Tanh(),
        )

    def forward(self, x):
        return self.net(x) * self.action_limit


class Critic(nn.Module):
    def __init__(self, state_dim, action_dim):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(state_dim + action_dim, 128),
            nn.ReLU(),
            nn.Linear(128, 128),
            nn.ReLU(),
            nn.Linear(128, 1),
        )

    def forward(self, s, a):
        x = torch.cat([s, a], dim=1)
        return self.net(x)


# =========================================================
# DDPG AGENT
# =========================================================
class DDPGAgent:
    def __init__(self, state_dim, action_dim, action_limit):
        self.actor = Actor(state_dim, action_dim, action_limit).to(DEVICE)
        self.actor_target = Actor(state_dim, action_dim, action_limit).to(DEVICE)
        self.critic = Critic(state_dim, action_dim).to(DEVICE)
        self.critic_target = Critic(state_dim, action_dim).to(DEVICE)

        self.actor_target.load_state_dict(self.actor.state_dict())
        self.critic_target.load_state_dict(self.critic.state_dict())

        self.actor_opt = optim.Adam(self.actor.parameters(), lr=ACTOR_LR)
        self.critic_opt = optim.Adam(self.critic.parameters(), lr=CRITIC_LR)
        self.action_limit = action_limit
        self.update_step = 0

    def select_action(self, state, noise=None):
        s = torch.tensor(state, dtype=torch.float32, device=DEVICE).unsqueeze(0)
        with torch.no_grad():
            a = self.actor(s).cpu().numpy()[0]
        if noise is not None:
            a = a + noise
        return np.clip(a, -self.action_limit, self.action_limit)

    def train_step(self, replay: ReplayBuffer, batch_size: int):
        if len(replay) < batch_size:
            return None

        self.update_step += 1
        s, a, r, ns, d = replay.sample(batch_size)

        with torch.no_grad():
            next_a = self.actor_target(ns)
            next_q = self.critic_target(ns, next_a)
            target_q = r + GAMMA * (1.0 - d) * next_q

        current_q = self.critic(s, a)
        critic_loss = nn.MSELoss()(current_q, target_q)

        self.critic_opt.zero_grad()
        critic_loss.backward()
        self.critic_opt.step()

        actor_loss_val = None
        # delayed actor update
        if self.update_step % 2 == 0:
            pred_a = self.actor(s)
            actor_q = self.critic(s, pred_a).mean()
            action_reg = 0.02 * (pred_a / self.action_limit).pow(2).mean()
            actor_loss = -actor_q + action_reg

            self.actor_opt.zero_grad()
            actor_loss.backward()
            self.actor_opt.step()

            self.soft_update(self.actor, self.actor_target)
            self.soft_update(self.critic, self.critic_target)
            actor_loss_val = float(actor_loss.item())
        else:
            self.soft_update(self.critic, self.critic_target)

        return {
            "critic_loss": float(critic_loss.item()),
            "actor_loss": actor_loss_val,
        }

    @staticmethod
    def soft_update(src, tgt):
        for src_p, tgt_p in zip(src.parameters(), tgt.parameters()):
            tgt_p.data.copy_(TAU * src_p.data + (1.0 - TAU) * tgt_p.data)


# =========================================================
# VALIDATION SCORE
# =========================================================
def validation_score(sim_df: pd.DataFrame):
    # เน้น cost ก่อน comfort
    return -(1.0 * sim_df["hourly_cost"].mean() + 0.8 * sim_df["T_dev"].abs().mean())


# =========================================================
# TRAINING
# =========================================================
def train_ddpg_for_alpha(data: pd.DataFrame, alpha: float):
    split_idx = int(len(data) * 0.8)
    train_part = data.iloc[:split_idx].reset_index(drop=True)
    val_part = data.iloc[split_idx:].reset_index(drop=True)

    env = HVACEnv(train_part, alpha=alpha, episode_len=EPISODE_LEN, dt_hours=DT_HOURS)
    agent = DDPGAgent(env.state_dim, env.action_dim, ACTION_MAX_DELTA)
    replay = ReplayBuffer(BUFFER_SIZE)

    reward_history = []
    loss_history = []
    global_step = 0

    best_score = -np.inf
    best_actor_state = None
    best_critic_state = None

    ou = OUNoise(size=env.action_dim, theta=OU_THETA, sigma=OU_SIGMA_START)

    for ep in range(TRAIN_EPISODES):
        state = env.reset()
        ou.reset()

        frac = ep / max(TRAIN_EPISODES - 1, 1)
        sigma_now = OU_SIGMA_START + frac * (OU_SIGMA_END - OU_SIGMA_START)
        ou.sigma = sigma_now

        done = False
        ep_reward = 0.0

        while not done:
            if global_step < WARMUP_STEPS:
                action = np.random.uniform(-ACTION_MAX_DELTA, ACTION_MAX_DELTA, size=(1,))
            else:
                noise = ou.sample()
                action = agent.select_action(state, noise=noise)

            next_state, reward, done, _ = env.step(action[0])
            replay.add(state, action, reward, next_state, done)

            state = next_state
            ep_reward += reward
            global_step += 1

            losses = agent.train_step(replay, BATCH_SIZE)
            if losses is not None:
                loss_history.append(losses)

        reward_history.append(ep_reward)

        if (ep + 1) % 10 == 0:
            val_env = HVACEnv(val_part, alpha=alpha, episode_len=min(EPISODE_LEN, len(val_part) - 2), dt_hours=DT_HOURS)
            state = val_env.reset(start_idx=0)
            done = False
            while not done:
                action = agent.select_action(state, noise=None)
                state, _, done, _ = val_env.step(action[0])

            val_sim = val_env.rollout_dataframe()
            score = validation_score(val_sim)

            if score > best_score:
                best_score = score
                best_actor_state = copy.deepcopy(agent.actor.state_dict())
                best_critic_state = copy.deepcopy(agent.critic.state_dict())

            print(
                f"alpha={alpha:.2f} "
                f"episode={ep+1}/{TRAIN_EPISODES} "
                f"reward={ep_reward:.2f} "
                f"val_score={score:.4f} "
                f"best_score={best_score:.4f} "
                f"ou_sigma={sigma_now:.3f}"
            )

    if best_actor_state is not None:
        agent.actor.load_state_dict(best_actor_state)
        agent.critic.load_state_dict(best_critic_state)

    return agent, reward_history, loss_history


# =========================================================
# EVALUATION
# =========================================================
def simulate_trained_policy(data: pd.DataFrame, alpha: float, agent: DDPGAgent, start_idx: int, episode_len: int):
    env = HVACEnv(data, alpha=alpha, episode_len=episode_len, dt_hours=DT_HOURS)
    state = env.reset(start_idx=start_idx)
    done = False

    while not done:
        action = agent.select_action(state, noise=None)
        next_state, reward, done, _ = env.step(action[0])
        state = next_state

    return env.rollout_dataframe()


# =========================================================
# METRICS
# =========================================================
def weekly_bill(df_sim):
    tmp = df_sim.copy()
    tmp["week_start"] = pd.to_datetime(tmp[DATETIME_COL]).dt.to_period("W").apply(lambda r: r.start_time)
    return (
        tmp.groupby("week_start", as_index=False)["hourly_cost"]
        .sum()
        .rename(columns={"hourly_cost": "weekly_bill"})
    )

def weekly_energy(df_sim):
    tmp = df_sim.copy()
    tmp["week_start"] = pd.to_datetime(tmp[DATETIME_COL]).dt.to_period("W").apply(lambda r: r.start_time)
    return (
        tmp.groupby("week_start", as_index=False)["E_hvac_kwh"]
        .sum()
        .rename(columns={"E_hvac_kwh": "weekly_energy"})
    )

def weekly_temp_dev(df_sim):
    tmp = df_sim.copy()
    tmp["week_start"] = pd.to_datetime(tmp[DATETIME_COL]).dt.to_period("W").apply(lambda r: r.start_time)
    return (
        tmp.groupby("week_start")["T_dev"]
        .agg(avg_temp_dev=lambda s: np.abs(s).mean())
        .reset_index()
    )

def rollout_metrics(df_sim):
    return {
        "mean_action": float(df_sim["action_delta_schedule"].mean()),
        "std_action": float(df_sim["action_delta_schedule"].std()),
        "mean_power_frac": float(df_sim["power_frac"].mean()),
        "mean_hourly_cost": float(df_sim["hourly_cost"].mean()),
        "mean_hourly_energy": float(df_sim["E_hvac_kwh"].mean()),
        "mean_abs_tdev": float(df_sim["T_dev"].abs().mean()),
    }


